# WhatsApp Gateway
PORT=3000
NODE_ENV=production

# Webhook URL to forward incoming messages to n8n
N8N_WEBHOOK_URL=https://your-n8n-instance.up.railway.app/webhook/whatsapp-incoming

# n8n API credentials (for direct DB access if needed)
N8N_API_KEY=your-n8n-api-key

# API Security
API_KEY=change-this-to-a-secure-random-string

# Database
DB_PATH=./data/crm.db

# WhatsApp Session
SESSION_PATH=./session

# Rate Limiting
MIN_DELAY_MS=8000
MAX_DELAY_MS=20000

# Retry
MAX_RETRIES=3
RETRY_DELAY_MS=60000
