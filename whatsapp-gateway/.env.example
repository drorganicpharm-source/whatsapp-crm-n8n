# Port the gateway listens on (Railway sets this automatically, no need to change)
PORT=3000

# Any random secret string - n8n must send this in the x-api-key header on every call
GATEWAY_API_KEY=change-me-to-a-long-random-string

# n8n Webhook URL that will receive every INCOMING WhatsApp message
# Example: https://your-n8n-instance.up.railway.app/webhook/whatsapp-incoming
N8N_INCOMING_WEBHOOK_URL=

# Where Baileys session/auth files are stored - point this to a mounted Railway Volume
# so the QR login session survives restarts/redeploys (otherwise you must re-scan every deploy)
AUTH_DIR=/app/auth_info

LOG_LEVEL=info
